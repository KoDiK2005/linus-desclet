{
    "clock-section": {
        "type": "header",
        "name": "Часы"
    },
    "use24h": {
        "type": "checkbox",
        "default": true,
        "description": "24-часовой формат"
    },
    "show-seconds": {
        "type": "checkbox",
        "default": true,
        "description": "Показывать секунды"
    },
    "colors-section": {
        "type": "header",
        "name": "Цвета"
    },
    "accent-color": {
        "type": "colorchooser",
        "default": "#e6161a",
        "description": "Акцентный красный цвет"
    },
    "time-color": {
        "type": "colorchooser",
        "default": "#ffffff",
        "description": "Цвет времени"
    },
    "mask-section": {
        "type": "header",
        "name": "Маска"
    },
    "show-mask": {
        "type": "checkbox",
        "default": true,
        "description": "Показывать маску"
    },
    "mask-size": {
        "type": "spinbutton",
        "default": 100,
        "min": 50,
        "max": 200,
        "step": 4,
        "units": "px",
        "description": "Размер маски"
    },
    "text-section": {
        "type": "header",
        "name": "Текст"
    },
    "time-font-size": {
        "type": "spinbutton",
        "default": 42,
        "min": 16,
        "max": 96,
        "step": 2,
        "units": "px",
        "description": "Размер шрифта часов"
    },
    "top-decor": {
        "type": "entry",
        "default": "PHANTOM THIEVES",
        "description": "Верхняя надпись-декор"
    },
    "bottom-decor": {
        "type": "entry",
        "default": "TAKE YOUR TIME",
        "description": "Нижняя надпись-декор"
    }
}
