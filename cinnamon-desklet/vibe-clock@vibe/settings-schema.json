{
    "general-section": {
        "type": "header",
        "description": "Общие"
    },
    "style": {
        "type": "combobox",
        "default": "anime",
        "description": "Стиль оформления",
        "options": {
            "Аниме": "anime",
            "Persona 5": "persona5",
            "Persona 4": "persona4",
            "Persona 3": "persona3"
        }
    },
    "use24h": {
        "type": "checkbox",
        "default": true,
        "description": "24-часовой формат",
        "tooltip": "Если выключено, время показывается в 12-часовом формате с AM/PM"
    },
    "show-seconds": {
        "type": "checkbox",
        "default": true,
        "description": "Показывать секунды"
    },

    "anime-section": {
        "type": "header",
        "description": "Оформление: Аниме",
        "dependency": "style=anime"
    },
    "anime-character": {
        "type": "combobox",
        "default": "sakura",
        "description": "Персонаж",
        "dependency": "style=anime",
        "options": {
            "Сакура (твинтейлы)": "sakura",
            "Луна (кошачьи ушки)": "luna",
            "Мико (каре, кимоно)": "miko",
            "Юки (хвост, очки)": "yuki"
        }
    },
    "anime-accent-color": {
        "type": "colorchooser",
        "default": "#ff6ec7",
        "description": "Основной неоновый цвет (часы, обводка)",
        "dependency": "style=anime"
    },
    "anime-glow-color": {
        "type": "colorchooser",
        "default": "#a239ff",
        "description": "Цвет свечения",
        "dependency": "style=anime"
    },
    "anime-date-color": {
        "type": "colorchooser",
        "default": "#c7b8ff",
        "description": "Цвет даты",
        "dependency": "style=anime"
    },
    "anime-bg-color": {
        "type": "colorchooser",
        "default": "#180a28",
        "description": "Цвет фона",
        "dependency": "style=anime"
    },
    "anime-show-icon": {
        "type": "checkbox",
        "default": true,
        "description": "Показывать персонажа",
        "dependency": "style=anime"
    },
    "anime-icon-size": {
        "type": "spinbutton",
        "default": 140,
        "min": 60,
        "max": 260,
        "step": 4,
        "units": "px",
        "description": "Размер персонажа",
        "dependency": "style=anime"
    },
    "anime-time-font-size": {
        "type": "spinbutton",
        "default": 40,
        "min": 16,
        "max": 96,
        "step": 2,
        "units": "px",
        "description": "Размер шрифта часов",
        "dependency": "style=anime"
    },
    "anime-top-decor": {
        "type": "entry",
        "default": "✦ 彡 sakura vibes 彡 ✦",
        "description": "Верхняя надпись-декор",
        "dependency": "style=anime"
    },
    "anime-bottom-decor": {
        "type": "entry",
        "default": "🌸 ⋆｡ ‧₊ ⋆ ☾ ⋆ ‧₊ ｡⋆ 🌸",
