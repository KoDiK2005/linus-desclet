{
    "general-section": {
        "type": "header",
        "description": "Общие"
    },
    "style": {
        "type": "combobox",
        "default": "anime",
        "description": "Стиль оформления",
        "options": {
            "Аниме": "anime",
            "Persona 5": "persona5"
        }
    },
    "use24h": {
        "type": "checkbox",
        "default": true,
        "description": "24-часовой формат",
        "tooltip": "Если выключено, время показывается в 12-часовом формате с AM/PM"
    },
    "show-seconds": {
        "type": "checkbox",
        "default": true,
        "description": "Показывать секунды"
    },

    "anime-section": {
        "type": "header",
        "description": "Оформление: Аниме",
        "dependency": "style=anime"
    },
    "anime-accent-color": {
        "type": "colorchooser",
        "default": "#ff6ec7",
        "description": "Основной неоновый цвет (часы, обводка)",
        "dependency": "style=anime"
    },
    "anime-glow-color": {
        "type": "colorchooser",
        "default": "#a239ff",
        "description": "Цвет свечения",
        "dependency": "style=anime"
    },
    "anime-date-color": {
        "type": "colorchooser",
        "default": "#c7b8ff",
        "description": "Цвет даты",
        "dependency": "style=anime"
    },
    "anime-bg-color": {
        "type": "colorchooser",
        "default": "#180a28",
        "description": "Цвет фона",
        "dependency": "style=anime"
    },
    "anime-show-sprite": {
        "type": "checkbox",
        "default": true,
        "description": "Показывать спрайт персонажа",
        "dependency": "style=anime"
    },
    "anime-sprite-size": {
        "type": "spinbutton",
        "default": 120,
        "min": 60,
        "max": 240,
        "step": 4,
        "units": "px",
        "description": "Размер спрайта",
        "dependency": "style=anime"
    },
    "anime-time-font-size": {
        "type": "spinbutton",
        "default": 40,
        "min": 16,
        "max": 96,
        "step": 2,
        "units": "px",
        "description": "Размер шрифта часов",
        "dependency": "style=anime"
    },
    "anime-top-decor": {
        "type": "entry",
        "default": "✦ 彡 sakura vibes 彡 ✦",
        "description": "Верхняя надпись-декор",
        "dependency": "style=anime"
    },
    "anime-bottom-decor": {
        "type": "entry",
        "default": "🌸 ⋆｡ ‧₊ ⋆ ☾ ⋆ ‧₊ ｡⋆ 🌸",
        "description": "Нижняя надпись-декор",
        "dependency": "style=anime"
    },

    "persona-section": {
        "type": "header",
        "description": "Оформление: Persona 5",
        "dependency": "style=persona5"
    },
    "persona-accent-color": {
        "type": "colorchooser",
        "default": "#e6161a",
        "description": "Акцентный красный цвет",
        "dependency": "style=persona5"
    },
    "persona-time-color": {
        "type": "colorchooser",
        "default": "#ffffff",
        "description": "Цвет времени",
        "dependency": "style=persona5"
    },
    "persona-show-mask": {
        "type": "checkbox",
        "default": true,
        "description": "Показывать маску",
        "dependency": "style=persona5"
    },
    "persona-mask-size": {
        "type": "spinbutton",
        "default": 100,
        "min": 50,
        "max": 200,
        "step": 4,
        "units": "px",
        "description": "Размер маски",
        "dependency": "style=persona5"
    },
    "persona-time-font-size": {
        "type": "spinbutton",
        "default": 42,
        "min": 16,
        "max": 96,
        "step": 2,
        "units": "px",
        "description": "Размер шрифта часов",
        "dependency": "style=persona5"
    },
    "persona-top-decor": {
        "type": "entry",
        "default": "PHANTOM THIEVES",
        "description": "Верхняя надпись-декор",
        "dependency": "style=persona5"
    },
    "persona-bottom-decor": {
        "type": "entry",
        "default": "TAKE YOUR TIME",
        "description": "Нижняя надпись-декор",
        "dependency": "style=persona5"
    }
}
