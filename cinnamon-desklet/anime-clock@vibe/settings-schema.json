{
    "clock-section": {
        "type": "header",
        "name": "Часы"
    },
    "use24h": {
        "type": "checkbox",
        "default": true,
        "description": "24-часовой формат",
        "tooltip": "Если выключено, время показывается в 12-часовом формате с AM/PM"
    },
    "show-seconds": {
        "type": "checkbox",
        "default": true,
        "description": "Показывать секунды"
    },
    "colors-section": {
        "type": "header",
        "name": "Цвета"
    },
    "accent-color": {
        "type": "colorchooser",
        "default": "#ff6ec7",
        "description": "Основной неоновый цвет (часы, обводка)"
    },
    "glow-color": {
        "type": "colorchooser",
        "default": "#a239ff",
        "description": "Цвет свечения"
    },
    "date-color": {
        "type": "colorchooser",
        "default": "#c7b8ff",
        "description": "Цвет даты"
    },
    "bg-color": {
        "type": "colorchooser",
        "default": "#180a28",
        "description": "Цвет фона"
    },
    "sprite-section": {
        "type": "header",
        "name": "Персонаж"
    },
    "show-sprite": {
        "type": "checkbox",
        "default": true,
        "description": "Показывать спрайт персонажа"
    },
    "sprite-size": {
        "type": "spinbutton",
        "default": 120,
        "min": 60,
        "max": 240,
        "step": 4,
        "units": "px",
        "description": "Размер спрайта"
    },
    "text-section": {
        "type": "header",
        "name": "Текст"
    },
    "time-font-size": {
        "type": "spinbutton",
        "default": 40,
        "min": 16,
        "max": 96,
        "step": 2,
        "units": "px",
        "description": "Размер шрифта часов"
    },
    "top-decor": {
        "type": "entry",
        "default": "✦ 彡 sakura vibes 彡 ✦",
        "description": "Верхняя надпись-декор"
    },
    "bottom-decor": {
        "type": "entry",
        "default": "🌸 ⋆｡ ‧₊ ⋆ ☾ ⋆ ‧₊ ｡⋆ 🌸",
        "description": "Нижняя надпись-декор"
    }
}
